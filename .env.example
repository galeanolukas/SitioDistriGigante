# Configuración de Uber Direct API
# Obtén estas credenciales en https://developer.uber.com/

UBER_CLIENT_ID=tu_client_id_de_uber
UBER_CLIENT_SECRET=tu_client_secret_de_uber
UBER_ACCESS_TOKEN=tu_access_token_de_uber
UBER_REFRESH_TOKEN=tu_refresh_token_de_uber

# Entorno de Uber (sandbox o production)
UBER_ENVIRONMENT=sandbox

# Webhook URL para Uber (debe ser HTTPS en producción)
UBER_WEBHOOK_URL=https://www.distribuidoragigante.com/api/uber/webhook/

# Configuración de Google OAuth
GOOGLE_OAUTH2_CLIENT_ID=tu_google_client_id
GOOGLE_OAUTH2_CLIENT_SECRET=tu_google_client_secret
GOOGLE_OAUTH2_REDIRECT_URI=https://www.distribuidoragigante.com/auth/callback/

# Configuración de reCAPTCHA
RECAPTCHA_PUBLIC_KEY=tu_recaptcha_public_key
RECAPTCHA_PRIVATE_KEY=tu_recaptcha_private_key
